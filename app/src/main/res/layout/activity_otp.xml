<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:id="@+id/btn_back_otp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="#BBDDFF"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify phone"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/tv_otp_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTP sent to your number"
            android:textColor="#BBDDFF"
            android:textSize="12sp"
            android:layout_marginTop="3dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter the 4-digit code"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="20dp" />

        <!-- OTP boxes -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/otp1"
                android:layout_width="56dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/card_background" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/otp2"
                android:layout_width="56dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/card_background" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/otp3"
                android:layout_width="56dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/card_background" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/otp4"
                android:layout_width="56dp"
                android:layout_height="60dp"
                android:inputType="number"
                android:maxLength="1"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/card_background" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_resend_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resend code in 0:60"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tv_error_otp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Invalid OTP. Please try again."
            android:textColor="@color/red"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_verify_otp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Verify OTP"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"
            android:padding="14dp"
            android:layout_marginTop="20dp" />

        <Button
            android:id="@+id/btn_resend_otp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resend OTP"
            android:backgroundTint="@android:color/transparent"
            android:textColor="@color/primary"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>
</LinearLayout>